{% extends 'AppBundle:Search:display.html.twig' %}
{% import "AppBundle::macros.html.twig" as macros %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('react/css/card.css') }}" />
{% endblock %}

{% block javascripts %}
    {% javascripts '@AppBundle/Resources/public/js/ui.card.js' %}
    <script src="{{ asset_url }}"></script>
    {% endjavascripts %}
    <script type="text/javascript">
    {% if cards is defined and cards|length > 0 %}
        app.user.params.card_id = {{ cards[0].id }};
    {% endif %}
    </script>
    <script src="{{ asset('react/js/card.js') }}" defer></script>
{% endblock %}

{% block main %}
<div class="row">
    <div class="col-md-9">
        <div class="row">
            {% for card in cards %}
                {% include 'AppBundle:Search:card-front-react.html.twig' %}
                <br>
                {% include 'AppBundle:Search:card-back-react.html.twig' %}
                {% if includeReviews %}
                    {% include 'AppBundle:Search:display-card-related.html.twig' %}
                    {% include 'AppBundle:Search:display-card-reviews.html.twig' %}
                {% endif %}
            {% endfor %}
        </div>
    </div>
</div>

{% endblock %}
